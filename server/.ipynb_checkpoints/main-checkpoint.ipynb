   "source": [
    "from fastapi import FastAPI\n",
    "from pydantic import BaseModel\n",
    "from agent_service import agent\n",
    "\n",
    "app = FastAPI()\n",
    "\n",
    "\n",
    "class ChatRequest(BaseModel):\n",
    "    message: str\n",
    "\n",
    "\n",
    "@app.post(\"/chat\")\n",
    "def chat(req: ChatRequest):\n",
    "    return {\n",
    "        \"response\": agent(req.message)\n",
    "    }"
   ]
  }
 ],
